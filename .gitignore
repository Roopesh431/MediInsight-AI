# =====================================================
# MediInsight AI
# .gitignore
# =====================================================

# -------------------------
# Python
# -------------------------
.venv/
venv/
__pycache__/
*.py[cod]
*.pyd
*.so

# -------------------------
# Environment Variables
# -------------------------
.env
.env.*
backend/.env

# -------------------------
# Database
# -------------------------
*.db
*.sqlite3

# -------------------------
# Uploaded Files
# -------------------------
backend/uploads/*
!backend/uploads/.gitkeep

backend/extracted_text/*
!backend/extracted_text/.gitkeep

backend/analysis/*
!backend/analysis/.gitkeep

# -------------------------
# Python Cache
# -------------------------
.pytest_cache/
.mypy_cache/

# -------------------------
# Node
# -------------------------
node_modules/
frontend/node_modules/

# -------------------------
# React / Vite Build
# -------------------------
dist/
build/
frontend/dist/

# -------------------------
# Logs
# -------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# JetBrains
# -------------------------
.idea/

# -------------------------
# Operating System
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Coverage
# -------------------------
coverage/
htmlcov/

# -------------------------
# Misc
# -------------------------
*.tmp
*.bak
*.swp